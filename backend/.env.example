# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/school_management

# Secret key for JWT tokens — use a long random string in production
SECRET_KEY=change-this-to-a-long-random-string

# Flask environment: development or production
FLASK_ENV=development

# Folder where uploaded files are stored (relative to backend/)
UPLOAD_FOLDER=uploads

# Max upload size in bytes (default: 10MB)
MAX_CONTENT_LENGTH=10485760
